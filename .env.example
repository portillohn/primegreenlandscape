# Environment Variables — Prime Green Landscape
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.

# ─── Stripe ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Firebase (Client SDK — public, safe to expose) ───────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (Server-side only — KEEP SECRET) ─────────────────────
# Option A: JSON credentials as a single env var (recommended for Vercel)
FIREBASE_ADMIN_CREDENTIALS={"type":"service_account","project_id":"..."}

# Option B: Individual fields (alternative)
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Firebase UID of the admin user (used for route protection)
NEXT_PUBLIC_ADMIN_UID=

# ─── Google Maps (for address autocomplete) ───────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Email (optional — for transactional emails) ──────────────────────────────
# SENDGRID_API_KEY=
# EMAIL_FROM=hello@primegreenlandscape.com
